# Arquivo de exemplo para variáveis de ambiente e chaves de API.
# Crie uma cópia deste arquivo com o nome `.env` ou adicione os valores
# diretamente nos arquivos protegidos (como lib/services/app_secrets.dart),
# dependendo da sua estratégia de gerenciamento de secrets.

# Google Generative AI (Gemini)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Groq (Fallback para IA)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# TMDb (The Movie Database) Bearer Token
# Obtenha em: https://www.themoviedb.org/settings/api
TMDB_BEARER_TOKEN=YOUR_TMDB_BEARER_TOKEN_HERE

# Supabase
# Obtenha em: Configurações do seu projeto Supabase > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
